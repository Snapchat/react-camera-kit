{
  "name": "@snap/react-camera-kit",
  "version": "0.1.0",
  "description": "React Camera Kit for web applications",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "sync-version": "bash scripts/sync-version.sh",
    "prebuild": "npm run sync-version",
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "watch": "tsc -p tsconfig.esm.json --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "npm run sync-version && husky",
    "demo:install": "npm --prefix demo install",
    "demo:dev": "npm --prefix demo run dev",
    "demo:typecheck": "npm --prefix demo run typecheck",
    "demo:build": "npm --prefix demo run build"
  },
  "keywords": [
    "react",
    "camera",
    "webcam",
    "sdk",
    "camera-kit",
    "camera kit",
    "Snap",
    "Snapchat",
    "Augmented Reality",
    "AR",
    "Lens"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Snapchat/react-camera-kit.git"
  },
  "homepage": "https://github.com/Snapchat/react-camera-kit#readme",
  "dependencies": {
    "stable-hash": "^0.0.6"
  },
  "peerDependencies": {
    "@snap/camera-kit": "^1.13.0",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0",
    "rxjs": ">=7"
  },
  "devDependencies": {
    "@snap/camera-kit": "^1.13.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
